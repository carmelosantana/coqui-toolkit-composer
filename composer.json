{
    "name": "coquibot/coqui-toolkit-composer",
    "description": "Composer dependency management toolkit for Coqui — install, remove, inspect, and update packages in the workspace",
    "version": "0.1.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Carmelo Santana"
        }
    ],
    "keywords": [
        "php-agents",
        "coqui",
        "composer",
        "toolkit",
        "package-management"
    ],
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "carmelosantana/php-agents": "^0.5"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "CoquiBot\\Toolkits\\Composer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CoquiBot\\Toolkits\\Composer\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "php-agents": {
            "toolkits": [
                "CoquiBot\\Toolkits\\Composer\\ComposerToolkit"
            ],
            "description": "Composer dependency management for Coqui workspaces"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
